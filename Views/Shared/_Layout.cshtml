<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bus_Booking_System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Bus_Booking_System.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Bus_Booking_System</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                           

                        </li>
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit">Logout</button>
                                @Html.AntiForgeryToken()
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row text-md-start">
                <div class="col-md-4 col-lg-4 col-xl-4 mx-auto mb-4">
                    <h5 class="fw-bold mb-4">
                        <i class="bi bi-bus-front me-2"></i>BusBooking
                    </h5>
                    <p class="text-muted" style="font-size: 0.9rem; line-height: 1.6;">
                        Your trusted platform for booking comfortable and affordable bus trips across the country.
                    </p>
                </div>

                <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mb-4">
                    <h6 class="fw-bold mb-4">Quick Links</h6>
                    <ul class="list-unstyled mb-0 footer-links">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">Home</a></li>
                        <li class="mb-2"><a asp-controller="Trip" asp-action="Index" class="text-muted text-decoration-none">Trips</a></li>
                        <li class="mb-2"><a asp-controller="Account" asp-action="Index" class="text-muted text-decoration-none">Home</a></li>
                        <li class="mb-2"><a asp-action="Booking" class="text-muted text-decoration-none">My Bookings</a></li>
                        <li class="mb-2"><a asp-action="Admin" class="text-muted text-decoration-none">Admin</a></li>
                    </ul>
                </div>
                <div class="col-md-4 col-lg-3 col-xl-3 mx-auto mb-md-0 mb-4">
                    <h6 class="fw-bold mb-4">Contact</h6>
                    <p class="text-muted small mb-2">
                        <i class="bi bi-envelope me-2"></i> email: support@busbooking.com
                    </p>
                    <p class="text-muted small mb-2">
                        <i class="bi bi-telephone me-2"></i> Phone: +1 (555) 123-4567
                    </p>
                    <p class="text-muted small">
                        <i class="bi bi-geo-alt me-2"></i> Address: 123 Transit Ave, City
                    </p>
                </div>
            </div>

            <hr class="border-secondary my-4">

            <div class="row align-items-center">
                <div class="col-md-12 text-center">
                    <p class="text-muted small mb-0">
                        © @DateTime.Now.Year BusBooking. All rights reserved.
                    </p>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
